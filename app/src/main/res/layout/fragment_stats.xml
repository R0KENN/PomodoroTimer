<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="120dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flow"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Статистика"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.3"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 2x2 Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <!-- Сегодня -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СЕГОДНЯ"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvStatsToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-thin" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="задачи"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- За неделю -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ЗА НЕДЕЛЮ"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvStatsWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-thin" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="задач"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <!-- Минут -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="МИНУТ"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvStatsTotalMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-thin" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="в фокусе"
                    android:textColor="#66F97316"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Серия -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СЕРИЯ ДНЕЙ"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvStatsStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="52sp"
                        android:fontFamily="sans-serif-thin" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_fire" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="подряд"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Week Chart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_chart"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПРОДУКТИВНОСТЬ (НЕДЕЛЯ)"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.2"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:id="@+id/weekChartContainer"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:gravity="bottom" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
