<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="100dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Row 1: Today + Week -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="СЕГОДНЯ" android:textColor="@color/text_dim" android:textSize="9sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tvStatsToday" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:text="0" android:textColor="@color/text_primary"
                    android:textSize="52sp" android:fontFamily="sans-serif-thin" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="задачи" android:textColor="@color/text_dim" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ЗА НЕДЕЛЮ" android:textColor="@color/text_dim" android:textSize="9sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tvStatsWeek" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:text="0" android:textColor="@color/text_primary"
                    android:textSize="52sp" android:fontFamily="sans-serif-thin" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="задач" android:textColor="@color/text_dim" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Minutes + Streak -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="МИНУТ" android:textColor="@color/text_dim" android:textSize="9sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tvStatsTotalMin" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:text="0" android:textColor="@color/accent"
                    android:textSize="52sp" android:fontFamily="sans-serif-thin" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="в фокусе" android:textColor="#66F97316" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="СЕРИЯ ДНЕЙ" android:textColor="@color/text_dim" android:textSize="9sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvStatsStreak" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_primary" android:textSize="52sp"
                        android:fontFamily="sans-serif-thin" />
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginStart="8dp"
                        android:src="@drawable/ic_fire" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="подряд" android:textColor="@color/text_dim" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Total All + Best Day + Avg -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ВСЕГО" android:textColor="@color/text_dim" android:textSize="8sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tvStatsTotalAll" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="0" android:textColor="@color/text_primary"
                    android:textSize="32sp" android:fontFamily="sans-serif-thin" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="помодоро" android:textColor="@color/text_dim" android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ЛУЧШИЙ" android:textColor="@color/text_dim" android:textSize="8sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tvStatsBestDay" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="0" android:textColor="@color/accent"
                    android:textSize="32sp" android:fontFamily="sans-serif-thin" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="за день" android:textColor="#66F97316" android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="4dp" android:background="@drawable/bg_glass_stat_card"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="СРЕДНЕЕ" android:textColor="@color/text_dim" android:textSize="8sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tvStatsAvgDay" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="0" android:textColor="@color/text_primary"
                    android:textSize="32sp" android:fontFamily="sans-serif-thin" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="в день" android:textColor="@color/text_dim" android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Week Chart -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_chart" android:orientation="vertical" android:padding="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ПРОДУКТИВНОСТЬ (НЕДЕЛЯ)" android:textColor="@color/text_dim" android:textSize="9sp"
                android:fontFamily="sans-serif-medium" android:letterSpacing="0.2" android:layout_marginBottom="20dp" />
            <LinearLayout android:id="@+id/weekChartContainer" android:layout_width="match_parent"
                android:layout_height="160dp" android:gravity="bottom" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
