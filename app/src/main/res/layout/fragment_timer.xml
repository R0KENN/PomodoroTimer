<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="120dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Flow"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.2" />

        <!-- Timer Area -->
        <FrameLayout
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:id="@+id/timerCanvasContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/timerCenterText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25:00"
                    android:textColor="@color/text_primary"
                    android:textSize="80sp"
                    android:fontFamily="sans-serif-thin"
                    android:letterSpacing="-0.04" />

                <!-- Label pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_label_pill"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/dotIndicator"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="8dp"
                        android:background="@color/accent" />

                    <TextView
                        android:id="@+id/tvTimerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ФОКУС"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.2" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnReset"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_reset"
                android:background="@drawable/bg_btn_glass_circle"
                android:scaleType="centerInside"
                android:contentDescription="Сбросить"
                android:layout_marginEnd="20dp" />

            <LinearLayout
                android:id="@+id/btnStartPause"
                android:layout_width="180dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp">

                <ImageView
                    android:id="@+id/ivBtnIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_play"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tvBtnLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Старт"
                    android:textColor="#FF582200"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnSkip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_skip"
                android:background="@drawable/bg_btn_glass_circle"
                android:scaleType="centerInside"
                android:contentDescription="Пропустить"
                android:layout_marginStart="20dp" />
        </LinearLayout>

        <!-- Progress Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ежедневный прогресс"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvTodayCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" / 8 сессий"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_fire" />
            </LinearLayout>

            <!-- Mini bar chart -->
            <LinearLayout
                android:id="@+id/miniChart"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="bottom" />

            <!-- Day labels -->
            <LinearLayout
                android:id="@+id/miniChartLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Settings chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ВРЕМЯ ФОКУСА"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView android:id="@+id/chipWork15"
                    android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                    android:layout_marginEnd="8dp" android:background="@drawable/bg_chip_inactive"
                    android:gravity="center" android:text="15 мин" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium" />

                <TextView android:id="@+id/chipWork25"
                    android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                    android:layout_marginEnd="8dp" android:background="@drawable/bg_chip_active"
                    android:gravity="center" android:text="25 мин" android:textColor="@color/white"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium" />

                <TextView android:id="@+id/chipWork45"
                    android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                    android:background="@drawable/bg_chip_inactive"
                    android:gravity="center" android:text="45 мин" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ВРЕМЯ ОТДЫХА"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView android:id="@+id/chipBreak5"
                    android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                    android:layout_marginEnd="8dp" android:background="@drawable/bg_chip_active"
                    android:gravity="center" android:text="5 мин" android:textColor="@color/white"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium" />

                <TextView android:id="@+id/chipBreak10"
                    android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                    android:layout_marginEnd="8dp" android:background="@drawable/bg_chip_inactive"
                    android:gravity="center" android:text="10 мин" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium" />

                <TextView android:id="@+id/chipBreak15"
                    android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                    android:background="@drawable/bg_chip_inactive"
                    android:gravity="center" android:text="15 мин" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
